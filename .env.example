# =====================================================================
# STERAS Environment Variables Template
# =====================================================================
# Copy this file to `.env` and fill in the real values.
# Never commit the real `.env` file.
# =====================================================================

# ----- Firebase Web App Config (from Firebase Console > Project Settings) -----
# These are PUBLIC — Firebase security comes from Firestore Rules, not API key hiding.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ----- External APIs (server-side only — used by Cloud Functions) -----
# MiniMax M3 — Anthropic-compatible API
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.MiniMax.com/v1
MINIMAX_MODEL=MiniMax-M3

# OpenWeather API (free tier: 1000 calls/day)
OPENWEATHER_API_KEY=

# ----- Optional -----
# If using Firebase emulators, set this to "true" in local dev
VITE_USE_FIREBASE_EMULATOR=false
