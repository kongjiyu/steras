rules_version = '2';

// =====================================================================
// STERAS Firestore Security Rules
// =====================================================================
// Roles:
//   - organizer:  can edit own Draft or AmendmentRequested applications
//   - authority:  can read only applications assigned to their agency
//   - public:     can read only `public_events` collection (read-only, no auth)
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isOrganizer() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organizer';
    }

    function isAuthority() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'authority';
    }

    function isOwner(organizerId) {
      return isSignedIn() && request.auth.uid == organizerId;
    }

    function isAssignedAuthority(eventId) {
      return isAuthority()
             && get(/databases/$(database)/documents/events/$(eventId)).data.requiredAuthorities.hasAny([
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityType
             ]);
    }

    function isEditable(status) {
      return status == 'Draft' || status == 'AmendmentRequested';
    }

    // ---- users collection ----
    // Organizers and authorities can read their own profile.
    // Authorities can read other authorities' profiles (for assignment/coordination).
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId
                    || (isAuthority() && resource.data.role == 'authority'));
      // Users can create their own profile on signup.
      allow create: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role == 'organizer'
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                      'uid', 'name', 'email', 'role', 'phone',
                      'createdAt', 'updatedAt', '_serverCreatedAt'
                    ]);
      // Users can update their own non-role fields.
      // Role changes are server-only (set by Cloud Functions / admin SDK).
      allow update: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'name', 'email', 'phone', 'updatedAt'
                    ]);
      allow delete: if false; // disable client-side deletion
    }

    // ---- events collection ----
    match /events/{eventId} {
      // Organizer can read their own event.
      // Assigned authorities can read applications for their agency.
      // Public viewers should query `public_events` instead — not `events`.
      allow read: if (isSignedIn() && isAuthority()
                       && resource.data.requiredAuthorities.hasAny([
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityType
                       ]))
                  || (isSignedIn() && isOwner(resource.data.organizerId));

      // Drafts are client-created. Submission and resubmission are server-only.
      allow create: if isOrganizer()
                    && request.resource.data.organizerId == request.auth.uid
                    && request.resource.data.status == 'Draft'
                    && request.resource.data.currentVersionNumber == 0
                    && request.resource.data.editableVersionId == 'v1'
                    && request.resource.data.draftDocumentPaths.size() == 0
                    && request.resource.data.requiredAuthorities.size() == 0;

      // Submitted Pending versions are immutable. Generated pointers and status
      // transitions are server-owned.
      allow update: if isOwner(resource.data.organizerId)
                    && isEditable(resource.data.status)
                    && request.resource.data.organizerId == resource.data.organizerId
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.status == resource.data.status
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'currentVersionId', 'currentAssessmentId', 'currentResourceId',
                      'requiredAuthorities', 'currentVersionNumber', 'editableVersionId',
                      'submittedAt'
                    ]);

      // Status transitions to Approved/Rejected/UnderReview are server-only (Cloud Functions).
      allow delete: if false;

      match /versions/{versionId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false;
      }

      match /assessments/{assessmentId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false;
      }

      // ---- Sub-collection: resources ----
      // Written by Cloud Functions only.
      match /resources/{resourceId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false; // server-only
      }

      match /decisions/{decisionId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false;
      }

      match /decision_history/{historyId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false;
      }

      match /resource_overrides/{overrideId} {
        allow read: if (isSignedIn() && isAssignedAuthority(eventId))
                    || (isSignedIn() && isOwner(get(/databases/$(database)/documents/events/$(eventId)).data.organizerId));
        allow write: if false;
      }

      // ---- Sub-collection: audit_logs ----
      // Append-only. Read by authorities. Never client-writable.
      match /audit_logs/{logId} {
        allow read: if isSignedIn() && isAssignedAuthority(eventId);
        allow write: if false; // server-only
      }
    }

    // ---- venues (read-only for all signed-in users, write = admin/seed) ----
    match /venues/{venueId} {
      allow read: if isSignedIn();
      allow write: if false; // seeded via admin SDK / Cloud Functions
    }

    // ---- incidents (synthetic dataset — read-only) ----
    match /incidents/{incidentId} {
      allow read: if isSignedIn() && isAuthority();
      allow write: if false;
    }

    // ---- public_events (read-only for everyone, written by Cloud Functions) ----
    match /public_events/{eventId} {
      allow read: if true;
      allow write: if false; // server-only
    }
  }
}
