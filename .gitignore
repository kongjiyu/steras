# =====================================================================
# STERAS — .gitignore
# =====================================================================

# ----- Dependencies -----
node_modules/
**/node_modules/
jspm_packages/

# ----- Build outputs -----
dist/
build/
lib/
out/
**/dist/
**/build/
**/lib/
**/out/
**/.vite/
*.tsbuildinfo
**/*.tsbuildinfo
# Explicit patterns — **/lib/ alone didn't match functions/lib/ on macOS git 2.50
functions/lib/
frontend/lib/

# ----- Test coverage -----
coverage/
.nyc_output/
**/coverage/

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tgz

# ----- Environment & secrets -----
# Real env files (with actual secrets) — never commit
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.envrc
functions/.env
functions/.env.local
functions/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local
.runtimeconfig.json
# Allow the templates to be committed
!frontend/.env.example
!functions/.env.example
!.env.example
!docs/.env.example

# ----- Firebase -----
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
*-debug.log
.firebase/hosting.*.cache
firestore-debug.log.*

# ----- IDE / Editor -----
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
*.bak
*.orig
*.rej
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- Cache / temp -----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.rpt2_cache/
.rts2_cache_cjs/
.tsbuildinfo
*.tmp
*.temp

# ----- OS -----
ehthumbs.db
[Tt]humbs.db
$RECYCLE.BIN/

# ----- Misc -----
*.local
*.pid
*.seed
*.pid.lock
.history/
