# Cloud Functions env vars (server-side only — never expose to client).
# Set via `firebase functions:secrets:set` for production, or in
# .runtimeconfig.json for local emulators.

# MiniMax M3 — Anthropic-compatible LLM (PRD §3)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.MiniMax.com/v1
MINIMAX_MODEL=MiniMax-M3

# OpenWeather API (free tier: 1000 calls/day)
OPENWEATHER_API_KEY=
