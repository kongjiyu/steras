# Non-secret Cloud Functions configuration.
# API keys belong in Cloud Secret Manager or functions/.secret.local.

# MiniMax M3 — Anthropic-compatible LLM (PRD §3)
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3

# Local/admin-only authority provisioning (never commit a real password)
AUTHORITY_EMAIL=
AUTHORITY_PASSWORD=
AUTHORITY_NAME=
AUTHORITY_TYPE=PDRM
